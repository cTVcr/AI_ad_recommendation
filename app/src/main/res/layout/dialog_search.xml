<?xml version="1.0" encoding="utf-8"?>
<!-- 对话式广告助手 - 微信聊天风格 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F0F0">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:background="#FFFFFF"
        android:elevation="1dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="AI 广告助手" android:textColor="#333333"
            android:textSize="16sp" android:textStyle="bold" />
        <TextView android:id="@+id/search_close" android:layout_width="30dp"
            android:layout_height="30dp" android:gravity="center" android:text="X"
            android:textColor="#999999" android:textSize="16sp" android:clickable="true" />
    </LinearLayout>

    <!-- 聊天消息 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/search_chat_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:clipToPadding="false" />

    <!-- 底部输入 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:gravity="center_vertical" android:padding="8dp"
        android:background="#FFFFFF" android:elevation="2dp"
        android:orientation="horizontal">

        <EditText android:id="@+id/search_input" android:layout_width="0dp"
            android:layout_height="38dp" android:layout_weight="1" android:hint="说点什么..."
            android:inputType="text" android:paddingHorizontal="12dp"
            android:background="@drawable/bg_search_input" android:textSize="14sp"
            android:textColor="#333333" android:textColorHint="#AAAAAA"
            android:imeOptions="actionSend" android:maxLines="2" />

        <TextView android:id="@+id/search_send" android:layout_width="48dp"
            android:layout_height="38dp" android:layout_marginStart="6dp"
            android:gravity="center" android:text="发送" android:textColor="#FF6B6B"
            android:textSize="14sp" android:textStyle="bold"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>
</LinearLayout>
