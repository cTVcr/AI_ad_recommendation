<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F6F0"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- 顶部色块（圆角，和卡片风格一致） -->
        <FrameLayout
            android:id="@+id/detail_media_container"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_rounded">

            <ImageView
                android:id="@+id/detail_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/detail_banner_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="广告标题"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="24dp"
                android:maxLines="2"
                android:shadowColor="#40000000"
                android:shadowRadius="6" />

            <com.tao.android.ai_ad_recommendation.ui.component.VideoPlayerView
                android:id="@+id/detail_video_player"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!-- 静音切换按钮（左上角，不挡控制栏） -->
            <ImageView
                android:id="@+id/detail_mute_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|start"
                android:layout_margin="10dp"
                android:src="@drawable/ic_volume_on"
                android:background="@drawable/bg_play_button"
                android:padding="8dp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- 信息卡片（白底圆角） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_rounded"
            android:padding="18dp"
            android:elevation="1dp">

            <TextView
                android:id="@+id/detail_advertiser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="广告主"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:drawableStart="@drawable/ic_verified"
                android:drawablePadding="4dp" />

            <TextView
                android:id="@+id/detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="广告标题"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="详细描述..."
                android:textColor="#999999"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp" />

            <LinearLayout
                android:id="@+id/detail_tags_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp" />

            <com.tao.android.ai_ad_recommendation.ui.component.InteractionBar
                android:id="@+id/detail_interaction_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- 评论卡片 -->
        <LinearLayout
            android:id="@+id/detail_comments_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_rounded"
            android:padding="18dp"
            android:elevation="1dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 最新评论"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/detail_comments_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/detail_comments_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无评论，来说两句吧"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="16dp" />
        </LinearLayout>

        <!-- AI深度分析卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_rounded"
            android:padding="18dp"
            android:elevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🤖 AI 深度分析"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_ai_refresh"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="⟳ 换一个"
                    android:textColor="#FF6B6B"
                    android:textSize="12sp"
                    android:paddingHorizontal="10dp"
                    android:background="@drawable/bg_tag_rounded"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/detail_ai_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/detail_ai_analysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI将根据广告内容生成深度分析报告..."
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ 亮点速览"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/detail_highlights_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 广告数据和标签 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_rounded"
                android:padding="14dp"
                android:layout_marginEnd="6dp"
                android:elevation="1dp">

                <TextView
                    android:id="@+id/detail_stat_impressions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12,580"
                    android:textColor="#FF6B6B"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👁 曝光"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_rounded"
                android:padding="14dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:elevation="1dp">

                <TextView
                    android:id="@+id/detail_stat_clicks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3,420"
                    android:textColor="#4CAF50"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👆 点击"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_rounded"
                android:padding="14dp"
                android:layout_marginStart="6dp"
                android:elevation="1dp">

                <TextView
                    android:id="@+id/detail_stat_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="27.2%"
                    android:textColor="#FF9800"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📈 点击率"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</ScrollView>
