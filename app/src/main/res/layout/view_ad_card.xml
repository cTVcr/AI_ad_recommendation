<?xml version="1.0" encoding="utf-8"?>
<!-- ====== 框架说明 ====== -->
<!-- 广告卡片组件布局 - 大图模式（默认） -->
<!-- 小图/视频模式通过AdCardView的Java代码动态切换 -->

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="2dp"
    android:background="@color/background_dark"
    android:clickable="true"
    android:focusable="true">

    <!-- 第一部分：主图/视频区域（大图模式占60%屏幕） -->
    <FrameLayout
        android:id="@+id/card_media_container"
        android:layout_width="match_parent"
        android:layout_height="300dp">

        <!-- 图片 -->
        <ImageView
            android:id="@+id/card_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#333333" />

        <!-- 视频播放器（默认隐藏，视频模式显示） -->
        <com.tao.android.ai_ad_recommendation.ui.component.VideoPlayerView
            android:id="@+id/card_video_player"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <!-- 第二部分：底部信息区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_card_gradient">

        <!-- 广告主名称 -->
        <TextView
            android:id="@+id/card_advertiser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="广告主"
            android:textColor="@color/text_light_gray"
            android:textSize="12sp"
            android:drawableStart="@drawable/ic_verified"
            android:drawablePadding="4dp" />

        <!-- 标题 -->
        <TextView
            android:id="@+id/card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="广告标题"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:maxLines="2" />

        <!-- AI摘要 -->
        <TextView
            android:id="@+id/card_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI摘要..."
            android:textColor="@color/text_light_gray"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:maxLines="3" />

        <!-- 标签容器（动态添加TagChipView） -->
        <LinearLayout
            android:id="@+id/card_tags_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp" />

        <!-- 互动按钮栏（复用组件） -->
        <com.tao.android.ai_ad_recommendation.ui.component.InteractionBar
            android:id="@+id/card_interaction_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</FrameLayout>
