<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:elevation="1dp"
    android:clickable="true"
    android:focusable="true">

    <!-- 顶部色块（顶部圆角与卡片吻合） -->
    <FrameLayout
        android:id="@+id/card_media_container"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/bg_card_top_rounded">

        <ImageView
            android:id="@+id/card_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/card_banner_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="广告标题"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp"
            android:maxLines="2"
            android:shadowColor="#40000000"
            android:shadowRadius="4" />

        <com.tao.android.ai_ad_recommendation.ui.component.VideoPlayerView
            android:id="@+id/card_video_player"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <!-- 底部信息：透明背景，继承卡片白色底 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/card_advertiser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="广告主"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:drawableStart="@drawable/ic_verified"
            android:drawablePadding="4dp" />

        <TextView
            android:id="@+id/card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="广告标题"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:maxLines="2" />

        <TextView
            android:id="@+id/card_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI摘要..."
            android:textColor="#999999"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:maxLines="2" />

        <LinearLayout
            android:id="@+id/card_tags_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp" />

        <com.tao.android.ai_ad_recommendation.ui.component.InteractionBar
            android:id="@+id/card_interaction_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
