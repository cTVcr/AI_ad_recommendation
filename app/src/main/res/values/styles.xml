<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AI_ad_recommendation" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">#F9F6F0</item>
        <item name="android:navigationBarColor">#F9F6F0</item>
        <item name="android:windowBackground">#F9F6F0</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- 启动页六字样式 -->
    <style name="SplashLetter">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">40sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FF6B6B</item>
        <item name="android:paddingHorizontal">4dp</item>
    </style>
</resources>
